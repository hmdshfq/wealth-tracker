{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": false
    },
    "playwriter": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "playwriter@latest"
      ],
      "enabled": false
    },
    "context-mode": {
      "type": "local",
      "command": [
        "context-mode"
      ]
    },
    "searxng": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "mcp-searxng"
      ],
      "enabled": false,
      "environment": {
        "SEARXNG_URL": "http://192.168.8.91:8085"
      }
    }
  },
  "plugin": [
    "context-mode",
    "opencode-agent-skills"
  ]
}
